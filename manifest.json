{
  "id": "recruitment-tracker",
  "name": "Recruitment Tracker",
  "version": "1.0.0",
  "description": "Manage rush and recruitment pipeline: add prospects, move them through stages (invited → rushed → bid → pledged), record votes and notes.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["recruitment", "rush", "greek", "pipeline", "prospects"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "adults",
    "requires_approval": false
  },
  "storage": "db",
  "nav": { "label": "Recruitment" },
  "icon": "🎓",
  "row_policies": {
    "prospects": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"]
    },
    "votes": {
      "kind": "owner_or_visibility",
      "member_column": "voter_id",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_owner_only": true
    },
    "prospect_activity": {
      "kind": "owner_or_visibility",
      "member_column": "actor_id",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_owner_only": true
    }
  },
  "ai_access": {
    "allowed": true,
    "mode": "read_write",
    "db_exports": ["prospects_summary"],
    "db_inserts": ["add_prospect"]
  }
}
